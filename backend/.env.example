# Application
APP_MODE=debug
APP_HOST=0.0.0.0
APP_PORT=8080
APP_CONTEXT_DURATION=5s
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL
PG_NAME=seamless
PG_USER=postgres
PG_PASSWORD=postgres
PG_HOST=localhost
PG_PORT=5432
PG_SSL_MODE=disable
PG_MAX_POOL=10
PG_TIMEOUT=1s
PG_CONN_ATTEMPTS=10

# Redis
REDIS_HOST=localhost
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_SESSION_PREFIX=session

# JWT
JWT_SECRET=change-me-super-secret
JWT_EXPIRE=15m
JWT_SESSION_EXPIRATION=24h

# S3 / MinIO
S3_ENDPOINT=localhost:9000
S3_REGION=us-east-1
S3_BUCKET=seamless-docs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# Nextcloud
NEXTCLOUD_BASE_URL=https://cloud.nastyn8.com
NEXTCLOUD_USERNAME=nextcloud-user
NEXTCLOUD_PASSWORD=nextcloud-password
NEXTCLOUD_ROOM_PREFIX=seamless
NEXTCLOUD_TIMEOUT=10s
NEXTCLOUD_TALK_BASE_URL=https://cloud.nastyn8.com

# GitHub webhook integration
GITHUB_WEBHOOK_SECRET=change-me-github-webhook-secret
GITHUB_BASE_URL=https://api.github.com
GITHUB_REPOSITORY_OWNER=your-org
GITHUB_REPOSITORY_NAME=your-repo
GITHUB_PROJECT_ID=1
GITHUB_ACTOR_USER_ID=1
GITHUB_TASK_KEY_PATTERN=([A-Z][A-Z0-9]+-\d+)

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=seamless
RABBITMQ_MEETING_RECORDINGS_QUEUE=meeting.recordings
RABBITMQ_ML_RESULTS_QUEUE=meeting.ml.results
RABBITMQ_ML_INTAKE_QUEUE=meeting.ml.intake
RABBITMQ_DEAD_LETTER_EXCHANGE=seamless.dlx
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_RETRY_DELAY=1h
